<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RSS 阅读器</title>
<style>
  /* Catppuccin Mocha */
  :root {
    --ctp-rosewater: #f5e0dc;
    --ctp-flamingo: #f2cdcd;
    --ctp-pink: #f5c2e7;
    --ctp-mauve: #cba6f7;
    --ctp-red: #f38ba8;
    --ctp-maroon: #eba0ac;
    --ctp-peach: #fab387;
    --ctp-yellow: #f9e2af;
    --ctp-green: #a6e3a1;
    --ctp-teal: #94e2d5;
    --ctp-sky: #89dceb;
    --ctp-sapphire: #74c7ec;
    --ctp-blue: #89b4fa;
    --ctp-lavender: #b4befe;
    --ctp-text: #cdd6f4;
    --ctp-subtext1: #bac2de;
    --ctp-subtext0: #a6adc8;
    --ctp-overlay2: #9399b2;
    --ctp-overlay1: #7f849c;
    --ctp-overlay0: #6c7086;
    --ctp-surface2: #585b70;
    --ctp-surface1: #45475a;
    --ctp-surface0: #313244;
    --ctp-base: #1e1e2e;
    --ctp-mantle: #181825;
    --ctp-crust: #11111b;

    --bg: var(--ctp-base);
    --card: var(--ctp-surface0);
    --text: var(--ctp-text);
    --muted: var(--ctp-subtext0);
    --accent: var(--ctp-blue);
    --border: var(--ctp-surface1);
    --sidebar-width: 260px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background:var(--bg);
    color:var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    line-height:1.6;
    display:flex;
    min-height:100vh;
  }
  .sidebar {
    width:var(--sidebar-width);
    background:var(--ctp-mantle);
    border-right:1px solid var(--border);
    padding:1.5rem 1rem;
    position:fixed;
    top:0; left:0; bottom:0;
    overflow-y:auto;
    z-index:10;
  }
  .sidebar h2 {
    font-size:1.2rem;
    color:var(--ctp-lavender);
    margin-bottom:0.75rem;
  }
  .appearance-panel {
    border-bottom:1px solid var(--border);
    padding-bottom:0.75rem;
    margin-bottom:0.75rem;
  }
  .appearance-panel .row {
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:0.5rem;
  }
  .appearance-panel label {
    font-size:0.75rem;
    color:var(--muted);
  }
  .appearance-panel .btn-group {
    display:flex;
    gap:2px;
  }
  .appearance-panel button {
    background:var(--card);
    border:1px solid var(--border);
    color:var(--text);
    padding:0.2rem 0.5rem;
    font-size:0.7rem;
    border-radius:4px;
    cursor:pointer;
    transition: background 0.2s;
  }
  .appearance-panel button.active {
    background:var(--accent);
    color:var(--ctp-crust);
    border-color:var(--accent);
  }
  .source-tree {
    margin-top:0.5rem;
  }
  .source-tree details {
    margin-bottom:0.25rem;
  }
  .source-tree summary {
    font-size:0.85rem;
    color:var(--ctp-lavender);
    cursor:pointer;
    padding:0.2rem 0;
    outline:none;
  }
  .source-tree .source-item {
    display:flex;
    align-items:center;
    padding-left:1rem;
    font-size:0.8rem;
    margin-bottom:0.25rem;
  }
  .source-item input[type="checkbox"] {
    margin-right:0.5rem;
    accent-color: var(--accent);
  }
  .tools {
    display:flex;
    gap:0.5rem;
    margin-top:0.75rem;
    padding-top:0.75rem;
    border-top:1px solid var(--border);
  }
  .tools button {
    background:var(--card);
    border:1px solid var(--border);
    color:var(--text);
    padding:0.25rem 0.6rem;
    font-size:0.75rem;
    border-radius:4px;
    cursor:pointer;
  }
  .tools button:hover { background:var(--border); }

  .main {
    margin-left:var(--sidebar-width);
    padding:2rem;
    flex:1;
    transition: max-width 0.3s, margin 0.3s;
  }
  /* 默认居中 */
  body.layout-center .main { max-width: 800px; }
  body.layout-left .main { max-width: none; }

  /* 列表视图（默认） */
  #articles-container.list-view article {
    display:block;
  }
  /* 瀑布视图 */
  #articles-container.masonry-view {
    columns: 2;
    column-gap: 1rem;
  }
  #articles-container.masonry-view article {
    break-inside: avoid;
    margin-bottom:1rem;
  }
  /* 网格视图 */
  #articles-container.grid-view {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  #articles-container.grid-view article {
    margin-bottom:0;
  }

  header {
    margin-bottom:2rem;
    padding-bottom:1rem;
    border-bottom:1px solid var(--border);
  }
  header h1 {
    font-size:1.5rem;
    color:var(--ctp-lavender);
  }
  header p {
    color:var(--muted);
    font-size:0.875rem;
    margin-top:0.25rem;
  }
  article {
    background:var(--card);
    border:1px solid var(--border);
    border-radius:8px;
    padding:1.25rem;
    margin-bottom:1rem;
    transition: border-color 0.2s;
  }
  article:hover {
    border-color:var(--accent);
  }
  article h2 {
    font-size:1.1rem;
    margin-bottom:0.25rem;
  }
  article h2 a {
    color:var(--accent);
    text-decoration:none;
  }
  article h2 a:hover {
    text-decoration:underline;
  }
  .meta {
    font-size:0.8rem;
    color:var(--muted);
    margin-bottom:0.75rem;
  }
  .meta span {
    margin-right:0.75rem;
  }
  .summary {
    font-size:0.9rem;
    color:var(--text);
    margin-bottom:0.5rem;
  }
  .content {
    font-size:0.85rem;
    color:var(--muted);
    max-height:12em;
    overflow:hidden;
    position:relative;
  }
  .content::after {
    content:'';
    position:absolute;
    bottom:0;
    left:0;
    right:0;
    height:3em;
    background:linear-gradient(transparent, var(--card));
  }
  .empty {
    text-align:center;
    padding:3rem;
    color:var(--muted);
  }
  footer {
    margin-top:3rem;
    text-align:center;
    font-size:0.75rem;
    color:var(--muted);
  }
  footer a { color:var(--accent); }

  @media (max-width: 768px) {
    body { flex-direction:column; }
    .sidebar {
      position:relative;
      width:100%;
      border-right:none;
      border-bottom:1px solid var(--border);
      padding:1rem;
    }
    .main {
      margin-left:0;
      padding:1rem;
      max-width:100%;
    }
    #articles-container.masonry-view { columns: 1; }
  }
</style>
</head>
<body class="layout-center">
<div class="sidebar">
  <h2>RSS 源</h2>

  <!-- 外观配置 -->
  <div class="appearance-panel">
    <div class="row">
      <label>对齐</label>
      <div class="btn-group" id="alignment-group">
        <button data-value="center" class="active">居中</button>
        <button data-value="left">左侧</button>
      </div>
    </div>
    <div class="row">
      <label>视图</label>
      <div class="btn-group" id="view-group">
        <button data-value="list" class="active">列表</button>
        <button data-value="masonry">瀑布</button>
        <button data-value="grid">网格</button>
      </div>
    </div>
  </div>

  <!-- 源树（JS动态构建） -->
  <div id="source-tree" class="source-tree"></div>

  <div class="tools">
    <button onclick="selectAll()">全选</button>
    <button onclick="deselectAll()">反选</button>
  </div>
</div>

<main class="main">
  <header>
    <h1>RSS 阅读器</h1>
    <p>最近 {{ period }} 小时 · 共 <span id="total-count">{{ count }}</span> 篇 · 生成于 {{ generated_at }}</p>
  </header>
  <div id="articles-container" class="list-view">
    {% for a in articles %}
    <article class="feed-article" data-source="{{ a.source }}">
      <h2><a href="{{ a.link or '#' }}" target="_blank" rel="noopener">{{ a.title }}</a></h2>
      <div class="meta">
        <span>来源: {{ a.source }}</span>
        <span>{{ a.published[:16] if a.published else '' }}</span>
      </div>
      {% if a.summary %}<div class="summary">{{ a.summary[:300] }}</div>{% endif %}
      {% if a.content %}<div class="content">{{ a.content[:600] }}</div>{% endif %}
    </article>
    {% endfor %}
    {% if not articles %}
    <div class="empty" id="empty-msg">暂无最近 {{ period }} 小时的文章</div>
    {% endif %}
  </div>
  <footer>
    <p>自动生成 · 每小时更新 · <a href="summary.json">AI 助理端点</a></p>
  </footer>
</main>

<script>
  // ----- 外观偏好持久化 -----
  (function() {
    const body = document.body;
    const alignBtns = document.querySelectorAll('#alignment-group button');
    const viewBtns = document.querySelectorAll('#view-group button');
    const container = document.getElementById('articles-container');

    function setActive(group, value) {
      group.forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }

    // 对齐
    const savedAlign = localStorage.getItem('rss-alignment') || 'center';
    body.classList.add('layout-' + savedAlign);
    setActive(alignBtns, savedAlign);
    alignBtns.forEach(btn => btn.addEventListener('click', () => {
      body.classList.remove('layout-center', 'layout-left');
      const val = btn.dataset.value;
      body.classList.add('layout-' + val);
      setActive(alignBtns, val);
      localStorage.setItem('rss-alignment', val);
    }));

    // 视图
    const savedView = localStorage.getItem('rss-view') || 'list';
    container.className = savedView + '-view';
    setActive(viewBtns, savedView);
    viewBtns.forEach(btn => btn.addEventListener('click', () => {
      const val = btn.dataset.value;
      container.className = val + '-view';
      setActive(viewBtns, val);
      localStorage.setItem('rss-view', val);
    }));
  })();

  // ----- 侧边栏源树构建 -----
  fetch('sources.json')
    .then(res => res.json())
    .then(sources => {
      const treeContainer = document.getElementById('source-tree');
      if (!sources.length) {
        treeContainer.innerHTML = '<div style="color:var(--muted);">暂无配置源</div>';
        return;
      }

      // 递归构建节点
      function buildTree(nodes, parentEl) {
        nodes.forEach(node => {
          if (node.type === 'folder') {
            const details = document.createElement('details');
            details.open = true; // 默认展开
            details.innerHTML = `<summary>${node.name}</summary>`;
            const innerDiv = document.createElement('div');
            details.appendChild(innerDiv);
            buildTree(node.children, innerDiv);
            parentEl.appendChild(details);
          } else if (node.type === 'source') {
            const div = document.createElement('div');
            div.className = 'source-item';
            div.innerHTML = `<input type="checkbox" id="src-${node.id}" checked onchange="filterArticles()" data-source="${node.name}">
                             <label for="src-${node.id}">${node.name}</label>`;
            parentEl.appendChild(div);
          }
        });
      }
      buildTree(sources, treeContainer);
    });

  // ----- 文章过滤（按源） -----
  function filterArticles() {
    const checkboxes = document.querySelectorAll('#source-tree input[type="checkbox"]');
    const visibleSources = new Set();
    checkboxes.forEach(cb => { if (cb.checked) visibleSources.add(cb.dataset.source); });

    let visibleCount = 0;
    document.querySelectorAll('.feed-article').forEach(article => {
      const source = article.dataset.source;
      if (visibleSources.has(source)) {
        article.style.display = '';
        visibleCount++;
      } else {
        article.style.display = 'none';
      }
    });
    document.getElementById('total-count').textContent = visibleCount;
    const emptyMsg = document.getElementById('empty-msg');
    if (emptyMsg) {
      emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  function selectAll() {
    document.querySelectorAll('#source-tree input[type="checkbox"]').forEach(cb => cb.checked = true);
    filterArticles();
  }
  function deselectAll() {
    document.querySelectorAll('#source-tree input[type="checkbox"]').forEach(cb => cb.checked = false);
    filterArticles();
  }
</script>
</body>
</html>